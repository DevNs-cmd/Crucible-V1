PORT=4000
NODE_ENV=development

# Supabase — from supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT — generate a random 32+ char string
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Groq AI — free at console.groq.com
GROQ_API_KEY=gsk_...

# n8n Webhooks — use placeholders until n8n is set up
N8N_WEBHOOK_NEW_LEAD=https://placeholder.example.com/webhook/new-lead
N8N_WEBHOOK_STATUS_CHANGE=https://placeholder.example.com/webhook/status-change
N8N_WEBHOOK_FOLLOWUP_REMINDER=https://placeholder.example.com/webhook/followup-reminder

# Gmail SMTP — use App Password from Google Account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="AlgoForce AI <your@gmail.com>"

# Cron — set true in production or to test locally
ENABLE_CRON=false
