PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Groq (free at console.groq.com)
GROQ_API_KEY=gsk_...

# n8n Webhooks
N8N_WEBHOOK_NEW_LEAD=https://your-n8n-instance/webhook/new-lead
N8N_WEBHOOK_STATUS_CHANGE=https://your-n8n-instance/webhook/status-change
N8N_WEBHOOK_FOLLOWUP_REMINDER=https://your-n8n-instance/webhook/followup-reminder

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
SMTP_FROM="AlgoForce AI <your@email.com>"

# Cron
ENABLE_CRON=false
